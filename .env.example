# 摄像头 ONVIF 配置
ONVIF_CAMERA_IP=192.168.68.216
ONVIF_CAMERA_PORT=8010
ONVIF_CAMERA_USERNAME=admin
ONVIF_CAMERA_PASSWORD=your password
ONVIF_CAMERA_PTZ_ENABLED=true
CAMERA_MEDIA_PROFILE_TOKEN=profile_1

# RTSP 视频流配置
RTSP_CAMERA_IP=192.168.68.216
RTSP_CAMERA_PORT=554
RTSP_CAMERA_USERNAME=admin
RTSP_CAMERA_PASSWORD=your password
RTSP_CAMERA_PATH=/Streaming/Channels/101
RTSP_CAMERA_PARAMS=transportmode=unicast&profile=Profile_1

# 摄像头移动速度配置
DEFAULT_CAMERA_SPEED=0.5
MAX_CAMERA_SPEED=1.0
MIN_CAMERA_SPEED=0.1

# 移动指令时间配置（秒）
PATROL_DURATION=12.5
CONTINUOUS_MOVE_DURATION=3
SHORT_MOVE_DURATION=1
CLEAR_OBSTRUCTION_DURATION=4.0

# 其他默认参数
NATURAL_LANGUAGE_CONTROL_SPEED=0.5
DEFAULT_ZOOM_DISTANCE=0.003
CONTINUOUS_ZOOM_DISTANCE=0.009

# 巡视方向配置
PATROL_DIRECTION=left

# AI 视觉交互配置
AI_API_URL=https://api.xiaozhi.me/vision/explain
AI_API_TOKEN=your-token-here
AI_TIMEOUT=15
DEFAULT_NAME_PREFIX=预设

# 预设点存储配置
PRESET_STORAGE_PATH=./presets.csv
COORDINATE_TOLERANCE=0.01

# 日志和捕获配置
ONVIF_CAMERA_CAPTURE=false
ONVIF_CAMERA_LOG=false
CAPTURES_DIR=./captures
